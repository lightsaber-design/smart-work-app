<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dark clock dial: smaller circle, so more light border shows -->
    <path
        android:pathData="M54,28 a26,26 0 1,0 0,52 a26,26 0 1,0 0,-52 Z"
        android:fillColor="#181D26"/>

    <!-- Subtle inner ring (light) -->
    <path
        android:pathData="M54,31 a23,23 0 1,0 0,46 a23,23 0 1,0 0,-46 Z"
        android:fillColor="#00000000"
        android:strokeColor="#E6E9EF"
        android:strokeWidth="1"
        android:strokeAlpha="0.3"/>

    <!-- Hour ticks (12 / 3 / 6 / 9), light on dark dial -->
    <path android:pathData="M54,30 L54,33" android:strokeColor="#E6E9EF" android:strokeWidth="2" android:strokeLineCap="round"/>
    <path android:pathData="M78,54 L75,54" android:strokeColor="#E6E9EF" android:strokeWidth="2" android:strokeLineCap="round"/>
    <path android:pathData="M54,78 L54,75" android:strokeColor="#E6E9EF" android:strokeWidth="2" android:strokeLineCap="round"/>
    <path android:pathData="M30,54 L33,54" android:strokeColor="#E6E9EF" android:strokeWidth="2" android:strokeLineCap="round"/>

    <!-- Hands (10:10), light -->
    <path android:pathData="M54,54 L44,48" android:strokeColor="#E6E9EF" android:strokeWidth="2.5" android:strokeLineCap="round"/>
    <path android:pathData="M54,54 L64,48" android:strokeColor="#E6E9EF" android:strokeWidth="2.5" android:strokeLineCap="round"/>

    <!-- Center dot (teal) -->
    <path
        android:pathData="M54,54 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0 Z"
        android:fillColor="#34B1AF"/>

</vector>
