<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget circular tipo el temporizador de la app (cuadrado 2x2).
  El anillo y el botón central se dibujan como Bitmap en TimerWidget.java
  (tintados con el color de la categoría). Aquí solo va la estructura.
  El contenido se mantiene MUY compacto para caber siempre dentro del círculo,
  incluso en el tamaño mínimo del widget (el botón ▶/⏹ no debe recortarse).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="2dp">

    <!-- Anillo circular (bitmap dibujado en código). Cuadrado y centrado. -->
    <ImageView
        android:id="@+id/widget_ring"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:scaleType="fitCenter"
        android:contentDescription="@null" />

    <!-- Contenido centrado dentro del círculo -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Chip de categoría (tocable para cambiarla cuando está parado) -->
        <TextView
            android:id="@+id/widget_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Predi"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/widget_chip_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:letterSpacing="0.02" />

        <!-- Cronómetro grande (corriendo) -->
        <Chronometer
            android:id="@+id/widget_elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="27sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Texto grande cuando está parado (hora actual o "Listo") -->
        <TextView
            android:id="@+id/widget_idle_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textSize="27sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:gravity="center" />

        <!-- Botón central play / stop (bitmap tintado) -->
        <ImageView
            android:id="@+id/widget_action_btn"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="3dp"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

    </LinearLayout>

</FrameLayout>
